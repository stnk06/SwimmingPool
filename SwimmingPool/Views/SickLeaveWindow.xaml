<mah:MetroWindow x:Class="SwimmingPool.Views.SickLeaveWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 Title="Оформление больничного и продление" Height="450" Width="450"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 SaveWindowPosition="True">
    <Grid Margin="25" x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- БЛОК ИНФОРМАЦИИ ОБ АБОНЕМЕНТЕ -->
        <Border Grid.Row="0" Margin="0,0,0,15" Padding="10" CornerRadius="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#E8F5E9"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasActiveMembership}" Value="False">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ActiveMembershipInfo}" TextWrapping="Wrap" FontWeight="SemiBold" HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#2E7D32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasActiveMembership}" Value="False">
                                <Setter Property="Foreground" Value="#C62828"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <TextBlock Text="Дата начала больничного:" Grid.Row="1" Margin="0,0,0,8" FontSize="14" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        <DatePicker SelectedDate="{Binding StartDate}" Grid.Row="2" Margin="0,0,0,20" mah:TextBoxHelper.Watermark="Выберите дату начала"/>

        <TextBlock Text="Дата окончания больничного:" Grid.Row="3" Margin="0,0,0,8" FontSize="14" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
        <DatePicker SelectedDate="{Binding EndDate}" Grid.Row="4" Margin="0,0,0,20" mah:TextBoxHelper.Watermark="Выберите дату окончания"/>

        <Border Grid.Row="5" Background="{DynamicResource MahApps.Brushes.Accent4}" CornerRadius="4" Padding="15" Margin="0,0,0,20">
            <TextBlock Text="{Binding DaysCount, StringFormat='К переносу на абонемент: {0} дн.'}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}" HorizontalAlignment="Center"/>
        </Border>

        <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Grid.Row="6" 
                 mah:TextBoxHelper.Watermark="Номер справки, диагноз или примечания..." 
                 mah:TextBoxHelper.ClearTextButton="True"
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,25"/>

        <Button Content="СОХРАНИТЬ И ПРОДЛИТЬ" Command="{Binding SaveCommand}" Grid.Row="7" Height="45" FontSize="14" FontWeight="Bold" Style="{DynamicResource MahApps.Styles.Button.Square.Accent}"/>
    </Grid>
</mah:MetroWindow>