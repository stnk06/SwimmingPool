<mah:MetroWindow x:Class="SwimmingPool.Views.MembershipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="АБОНЕМЕНТ" SizeToContent="Height" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        BorderThickness="1" GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid Margin="25" x:Name="FormGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="24" FontWeight="Light" Margin="0,0,0,20"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Клиент:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,5" ItemsSource="{Binding Clients}" DisplayMemberPath="FullName" SelectedValuePath="ClientId" 
                      SelectedValue="{Binding Membership.ClientId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Grid.Row="1" Text="Тип абонемента:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,5" ItemsSource="{Binding MembershipTypes}" DisplayMemberPath="TypeName" SelectedValuePath="MembershipTypeId" 
                      SelectedValue="{Binding Membership.MembershipTypeId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Grid.Row="2" Text="Дата покупки:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <DatePicker Grid.Row="2" Grid.Column="1" Margin="0,5" SelectedDate="{Binding Membership.PurchaseDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Grid.Row="3" Text="Дата окончания:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <DatePicker Grid.Row="3" Grid.Column="1" Margin="0,5" SelectedDate="{Binding Membership.ExpiryDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" IsDefault="True" Click="SaveButton_Click" Margin="10 0 0 0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=FormGrid, Path=(Validation.HasError)}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Отмена" IsCancel="True" Margin="10 0 0 0"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>

