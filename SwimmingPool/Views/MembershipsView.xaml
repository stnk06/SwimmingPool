<UserControl x:Class="SwimmingPool.Views.MembershipsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:infra="clr-namespace:SwimmingPool.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Border Style="{StaticResource ContentCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- Фильтры -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0 0 0 15">
                <TextBlock Text="АБОНЕМЕНТЫ" FontSize="24" FontWeight="Light"/>
                <TextBlock Text="Учет проданных абонементов" Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0 5 0 0"/>
            </StackPanel>

            <!-- ПАНЕЛЬ ФИЛЬТРОВ -->
            <Border Grid.Row="1" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <!-- Поиск по клиенту -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Разделитель -->
                        <ColumnDefinition Width="1.5*"/>
                        <!-- Тип абонемента -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Разделитель -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Даты -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Сброс -->
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="Поиск по клиенту..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             Margin="0,0,10,0"/>

                    <GridSplitter Grid.Column="1" Width="1" Background="Transparent" Margin="5"/>

                    <ComboBox Grid.Column="2" ItemsSource="{Binding MembershipTypes}" 
                              SelectedItem="{Binding SelectedTypeFilter}"
                              DisplayMemberPath="TypeName"
                              mah:TextBoxHelper.Watermark="Тип абонемента"
                              mah:TextBoxHelper.ClearTextButton="True"
                              Margin="0,0,10,0"/>

                    <GridSplitter Grid.Column="3" Width="1" Background="Transparent" Margin="5"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <DatePicker SelectedDate="{Binding DateFrom}" mah:TextBoxHelper.Watermark="С даты" Width="100" Margin="0,0,5,0"/>
                        <TextBlock Text="-" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <DatePicker SelectedDate="{Binding DateTo}" mah:TextBoxHelper.Watermark="По дату" Width="100"/>
                    </StackPanel>

                    <Button Grid.Column="5" Command="{Binding ClearFilterCommand}" Style="{StaticResource MahApps.Styles.Button.Circle}" Width="30" Height="30" Margin="10,0,0,0" ToolTip="Сбросить фильтры">
                        <iconPacks:PackIconMaterial Kind="FilterOff" Width="12" Height="12"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="0 0 0 10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding AddMembershipCommand}" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Margin="0 0 5 0"/>
                            <TextBlock Text="Продать абонемент"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditMembershipCommand}" Margin="10 0 0 0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pencil" Margin="0 0 5 0"/>
                            <TextBlock Text="Изменить"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteMembershipCommand}" Margin="10 0 0 0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" Margin="0 0 5 0"/>
                            <TextBlock Text="Удалить"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <DataGrid Grid.Row="3" ItemsSource="{Binding MembershipsView}" SelectedItem="{Binding SelectedMembership}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding MembershipId}" Width="Auto"/>

                    <!-- Клиент с подсветкой (используем ClientFullName) -->
                    <DataGridTemplateColumn Header="Клиент" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock infra:TextBlockHighlighter.Text="{Binding ClientFullName}"
                                           infra:TextBlockHighlighter.Selection="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           infra:TextBlockHighlighter.HighlightBrush="{DynamicResource MahApps.Brushes.Accent}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Тип абонемента" Binding="{Binding MembershipTypeName}" Width="*"/>
                    <!-- Исправлено на PurchaseDate -->
                    <DataGridTextColumn Header="Дата покупки" Binding="{Binding PurchaseDate, StringFormat=dd.MM.yyyy}" Width="*"/>
                    <!-- Исправлено на ExpiryDate -->
                    <DataGridTextColumn Header="Действует до" Binding="{Binding ExpiryDate, StringFormat=dd.MM.yyyy}" Width="*"/>

                    <!-- Убран Price, так как его нет в вашей модели -->
                    <!-- <DataGridTextColumn Header="Стоимость" Binding="{Binding Price, StringFormat=C}" Width="*"/> -->
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>