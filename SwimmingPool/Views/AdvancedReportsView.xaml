<UserControl x:Class="SwimmingPool.Views.AdvancedReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:viewModels="clr-namespace:SwimmingPool.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=viewModels:AdvancedReportsViewModel}"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Border Style="{StaticResource ContentCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="РАСШИРЕННАЯ АНАЛИТИКА" FontSize="24" FontWeight="Light"/>
                    <TextBlock Text="Комплексные отчеты по всем направлениям деятельности" Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0 5 0 0"/>
                </StackPanel>

                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Style="{StaticResource MahApps.Styles.Button.Circle}" Width="40" Height="40" ToolTip="Обновить данные">
                    <iconPacks:PackIconMaterial Kind="Refresh"/>
                </Button>
            </Grid>

            <!-- Вкладки -->
            <TabControl Grid.Row="1" mah:TabControlHelper.Underlined="SelectedTabItem">

                <!-- ВКЛАДКА 1: ФИНАНСЫ -->
                <TabItem Header="Финансы и Продажи">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="1.5*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Кнопка экспорта -->
                        <Button Grid.Row="0" Command="{Binding ExportFinancialCommand}" HorizontalAlignment="Right" Margin="0,0,0,10" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,5,0"/>
                                <TextBlock Text="Экспорт: Финансы (PDF)"/>
                            </StackPanel>
                        </Button>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding RevenueSeries}" LegendLocation="None" Margin="0,0,0,20">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Период" Labels="{Binding RevenueLabels}"/>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Сумма" LabelFormatter="{Binding CurrencyFormatter}"/>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>

                        <DataGrid Grid.Row="2" ItemsSource="{Binding FinancialStats}" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Месяц" Binding="{Binding MonthYear}" Width="*"/>
                                <DataGridTextColumn Header="Продано абонементов" Binding="{Binding MembershipsSold}" Width="*"/>
                                <DataGridTextColumn Header="Ср. чек" Binding="{Binding AvgCheck, StringFormat='C'}" Width="*"/>
                                <DataGridTextColumn Header="Выручка" Binding="{Binding TotalRevenue, StringFormat='C'}" FontWeight="Bold" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- ВКЛАДКА 2: ТРЕНЕРЫ -->
                <TabItem Header="Эффективность тренеров">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Command="{Binding ExportTrainerCommand}" HorizontalAlignment="Right" Margin="0,0,0,10" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,5,0"/>
                                <TextBlock Text="Экспорт: Тренеры (PDF)"/>
                            </StackPanel>
                        </Button>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1.5*"/>
                            </Grid.ColumnDefinitions>

                            <DataGrid Grid.Column="0" ItemsSource="{Binding TrainerStats}" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,10,0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Тренер" Binding="{Binding TrainerName}" Width="*"/>
                                    <DataGridTextColumn Header="Специализация" Binding="{Binding Specialization}" Width="*"/>
                                    <DataGridTextColumn Header="Часы" Binding="{Binding TotalHours}" Width="Auto"/>
                                    <DataGridTextColumn Header="Ученики" Binding="{Binding TotalStudents}" Width="Auto"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <lvc:CartesianChart Grid.Column="1" Series="{Binding TrainerWorkloadSeries}" LegendLocation="None">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Тренер" Labels="{Binding TrainerLabels}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Отработано часов"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ВКЛАДКА 3: БАССЕЙНЫ -->
                <TabItem Header="Бассейны и Посещаемость">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Command="{Binding ExportPoolCommand}" HorizontalAlignment="Right" Margin="0,0,0,10" Style="{StaticResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0,0,5,0"/>
                                <TextBlock Text="Экспорт: Бассейны (PDF)"/>
                            </StackPanel>
                        </Button>

                        <GroupBox Grid.Row="1" Header="Загрузка бассейнов" Style="{DynamicResource MahApps.Styles.GroupBox}">
                            <DataGrid ItemsSource="{Binding PoolStats}" AutoGenerateColumns="False" IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Название бассейна" Binding="{Binding PoolName}" Width="2*"/>
                                    <DataGridTextColumn Header="Занятий" Binding="{Binding TotalClasses}" Width="*"/>
                                    <DataGridTextColumn Header="Посетителей" Binding="{Binding TotalVisitors}" Width="*"/>
                                    <DataGridTextColumn Header="Заполняемость (%)" Binding="{Binding OccupancyRate, StringFormat='{}{0}%'}" FontWeight="Bold" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Row="2" Header="Динамика посещений по дням недели" Style="{DynamicResource MahApps.Styles.GroupBox}" Margin="0,10,0,0">
                            <lvc:CartesianChart Series="{Binding AttendanceSeries}" LegendLocation="None">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Количество посещений"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Labels="{Binding AttendanceLabels}"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </GroupBox>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</UserControl>