<UserControl x:Class="SwimmingPool.Views.ClientsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:infra="clr-namespace:SwimmingPool.Infrastructure"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <Border Style="{StaticResource ContentCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="Auto"/>
                <!-- Фильтры -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопки действий -->
                <RowDefinition Height="*"/>
                <!-- Таблица -->
            </Grid.RowDefinitions>

            <!-- 1. Заголовок -->
            <StackPanel Grid.Row="0" Margin="0 0 0 10">
                <TextBlock Text="КЛИЕНТЫ" FontSize="24" FontWeight="Light"/>
                <TextBlock Text="Просмотр и управление базой клиентов бассейна" Foreground="{DynamicResource MahApps.Brushes.Gray3}" Margin="0 5 0 0"/>
            </StackPanel>

            <!-- 2. Панель Фильтров -->
            <Border Grid.Row="1" Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <!-- Поиск -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Разделитель -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Дата С -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Дата По -->
                        <ColumnDefinition Width="Auto"/>
                        <!-- Кнопка сброса -->
                    </Grid.ColumnDefinitions>

                    <!-- Поиск -->
                    <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="Поиск (ФИО, паспорт, телефон...)"
                             mah:TextBoxHelper.ClearTextButton="True"
                             mah:TextBoxHelper.UseFloatingWatermark="True"
                             Margin="0,0,15,0"/>

                    <GridSplitter Grid.Column="1" Width="1" Background="Transparent" Margin="5"/>

                    <!-- Дата рождения (Фильтр) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="Д.Р. с:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
                        <DatePicker SelectedDate="{Binding BirthDateFrom}" Width="110" Margin="0,0,10,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="по:" VerticalAlignment="Center" Margin="0,0,5,0" Foreground="Gray"/>
                        <DatePicker SelectedDate="{Binding BirthDateTo}" Width="110" Margin="0,0,10,0"/>
                    </StackPanel>

                    <!-- Сброс -->
                    <Button Grid.Column="4" Command="{Binding ClearFilterCommand}" Style="{StaticResource MahApps.Styles.Button.Circle}" Width="30" Height="30" Margin="5,0,0,0" ToolTip="Сбросить фильтры">
                        <iconPacks:PackIconMaterial Kind="FilterOff" Width="12" Height="12"/>
                    </Button>
                </Grid>
            </Border>

            <!-- 3. Кнопки -->
            <Grid Grid.Row="2" Margin="0 0 0 10">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding CreateContractCommand}" Margin="0,0,10,0" ToolTip="Сформировать договор в Word">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                                <Setter Property="Background" Value="#2B579A"/>
                                <Setter Property="BorderBrush" Value="#2B579A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="FileWord" Margin="0 0 5 0"/>
                            <TextBlock Text="Договор"/>
                        </StackPanel>
                    </Button>

                    <!-- НОВАЯ КНОПКА: БОЛЬНИЧНЫЙ -->
                    <Button Command="{Binding RegisterSickLeaveCommand}" Margin="0,0,10,0" ToolTip="Оформить больничный лист и заморозить абонемент">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                                <Setter Property="Background" Value="#E53935"/>
                                <!-- Красный цвет для медицинской тематики -->
                                <Setter Property="BorderBrush" Value="#E53935"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="MedicalBag" Margin="0 0 5 0"/>
                            <TextBlock Text="Больничный"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding AddClientCommand}" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountPlusOutline" Margin="0 0 5 0"/>
                            <TextBlock Text="Добавить"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding EditClientCommand}" Margin="10 0 0 0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountEditOutline" Margin="0 0 5 0"/>
                            <TextBlock Text="Изменить"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding DeleteClientCommand}" Margin="10 0 0 0">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountRemoveOutline" Margin="0 0 5 0"/>
                            <TextBlock Text="Удалить"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- 4. Таблица (Обновленная с подсветкой) -->
            <DataGrid Grid.Row="3" ItemsSource="{Binding ClientsView}" SelectedItem="{Binding SelectedClient}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <!-- ФИО с подсветкой -->
                    <DataGridTemplateColumn Header="ФИО" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock infra:TextBlockHighlighter.Text="{Binding FullName}"
                                           infra:TextBlockHighlighter.Selection="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           infra:TextBlockHighlighter.HighlightBrush="{DynamicResource MahApps.Brushes.Accent}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Дата рождения" Binding="{Binding DateOfBirth, StringFormat='dd.MM.yyyy'}" Width="Auto"/>

                    <!-- Паспорт с подсветкой -->
                    <DataGridTemplateColumn Header="Номер паспорта" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock infra:TextBlockHighlighter.Text="{Binding PassportNumber}"
                                           infra:TextBlockHighlighter.Selection="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           infra:TextBlockHighlighter.HighlightBrush="Orange"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Телефон с подсветкой -->
                    <DataGridTemplateColumn Header="Телефон" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock infra:TextBlockHighlighter.Text="{Binding PhoneNumber}"
                                           infra:TextBlockHighlighter.Selection="{Binding DataContext.SearchText, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Адрес" Binding="{Binding Address}" Width="1.5*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>