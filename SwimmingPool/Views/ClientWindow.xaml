<mah:MetroWindow x:Class="SwimmingPool.Views.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="КЛИЕНТ" 
        SizeToContent="Height" Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid Margin="25" x:Name="FormGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="24" FontWeight="Light" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="ФИО:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBox x:Name="FullNameBox" Grid.Row="0" Grid.Column="1" Margin="0,5" 
                         Text="{Binding Client.FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                         mah:TextBoxHelper.Watermark="Фамилия Имя Отчество"
                         PreviewTextInput="FullName_PreviewTextInput"
                         TextChanged="FullName_TextChanged"
                         LostFocus="FullName_LostFocus"/>

                <TextBlock Grid.Row="1" Text="Дата рождения:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <DatePicker Grid.Row="1" Grid.Column="1" Margin="0,5" SelectedDate="{Binding Client.DateOfBirth, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

                <TextBlock Grid.Row="2" Text="Номер паспорта:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBox x:Name="PassportBox" Grid.Row="2" Grid.Column="1" Margin="0,5" 
                         Text="{Binding Client.PassportNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         mah:TextBoxHelper.Watermark="0000 000000"
                         PreviewTextInput="Passport_PreviewTextInput"
                         TextChanged="Passport_TextChanged"
                         MaxLength="11"/>

                <TextBlock Grid.Row="3" Text="Телефон:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="1" Margin="0,5" 
                         Text="{Binding Client.PhoneNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                         mah:TextBoxHelper.Watermark="+7XXXXXXXXXX"
                         PreviewTextInput="Phone_PreviewTextInput"
                         TextChanged="Phone_TextChanged"
                         MaxLength="12"/>

                <TextBlock Grid.Row="4" Text="Адрес:" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Margin="0,5" Text="{Binding Client.Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
            </Grid>

            <Border Grid.Column="2" BorderThickness="1" BorderBrush="#EEEEEE" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="QR-код доступа" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,0,0,10"/>
                    <Image x:Name="QrImage" Width="150" Height="150" HorizontalAlignment="Center"/>

                    <Button Content="Обновить QR" Click="GenerateQr_Click" Margin="0,10,0,0" Style="{StaticResource MahApps.Styles.Button.Flat}"/>

                    <!-- Кнопка печати -->
                    <Button Click="PrintPdf_Click" Margin="0,5,0,0"  ToolTip="Сохранить пропуск в PDF">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Printer" Margin="0,0,5,0"/>
                            <TextBlock Text="Печать пропуска"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" IsDefault="True" Click="SaveButton_Click" Margin="10 0 0 0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=FormGrid, Path=(Validation.HasError)}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Отмена" IsCancel="True" Margin="10 0 0 0"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>