<UserControl x:Class="SwimmingPool.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000"
             Language="ru-RU">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,15" Padding="20" Background="#CC00ABA9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="МБУ ДО Климовская СШ. Брянская область" FontSize="16" Foreground="White" Opacity="0.8"/>
                    <TextBlock Text="Панель администратора" FontSize="28" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <!-- Удален ошибочный атрибут p="5" -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Background="#20FFFFFF" Margin="20,0,0,0">
                    <iconPacks:PackIconMaterial Kind="QrcodeScan" Width="30" Height="30" Foreground="White" VerticalAlignment="Center" Margin="10"/>
                    <TextBox Width="200" Height="35" Margin="0,0,10,0" FontSize="16"
                             Text="{Binding QrScannerInput, UpdateSourceTrigger=PropertyChanged}"
                             mah:TextBoxHelper.Watermark="Сканировать пропуск..."
                             mah:TextBoxHelper.ClearTextButton="True"
                             mah:ControlsHelper.CornerRadius="5"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <GroupBox Style="{DynamicResource MahApps.Styles.GroupBox}" Margin="0,0,0,20">
                    <GroupBox.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Статистика за сегодня"/>
                            <Button Command="{Binding RefreshWidgetsCommand}" Style="{StaticResource MahApps.Styles.Button.Chromeless}" Margin="10,0,0,0" ToolTip="Обновить">
                                <iconPacks:PackIconMaterial Kind="Refresh" Width="14" Height="14"/>
                            </Button>
                        </StackPanel>
                    </GroupBox.Header>
                    <Grid Margin="15" DataContext="{Binding TodaysStats}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="ПРОДАНО АБОНЕМЕНТОВ:" FontSize="11" Opacity="0.7"/>
                            <TextBlock Text="{Binding NewMembershipsToday}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="ВЫРУЧКА:" FontSize="11" Opacity="0.7"/>
                            <TextBlock Text="{Binding RevenueToday, StringFormat='C'}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Быстрые действия" Style="{DynamicResource MahApps.Styles.GroupBox}" Margin="0,0,0,20">
                    <Button Command="{Binding QuickRegisterCommand}" HorizontalContentAlignment="Left" Style="{StaticResource MahApps.Styles.Button.Flat}" Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="AccountPlusOutline" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Text="Быстрая регистрация" FontSize="15" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Button>
                </GroupBox>
            </StackPanel>

            <GroupBox Grid.Column="1" Header="Отметить посещение вручную" Style="{DynamicResource MahApps.Styles.GroupBox}" Margin="10,0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="1. Найдите клиента" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox Grid.Row="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             mah:TextBoxHelper.Watermark="Введите ФИО или номер телефона..."
                             mah:TextBoxHelper.ClearTextButton="True" Style="{StaticResource MahApps.Styles.TextBox}"/>

                    <ListBox Grid.Row="2" ItemsSource="{Binding SearchResults}" SelectedItem="{Binding SelectedClient}"
                             Margin="0,10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5">
                                    <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding PhoneNumber}" Opacity="0.7"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="3" Command="{Binding CheckInCommand}" Margin="0,10,0,0" Style="{StaticResource MahApps.Styles.Button.Dialogs.Accent}">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Check" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Отметить посещение"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Абонементы, истекающие на этой неделе" Style="{DynamicResource MahApps.Styles.GroupBox}" Margin="10,0,0,0">
                <ListBox ItemsSource="{Binding ExpiringMemberships}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding ClientFullName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MembershipTypeName}" Opacity="0.8"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Opacity="0.8">
                                    <Run Text="до"/> <Run Text="{Binding ExpiryDate, StringFormat='dd.MM.yyyy'}"/>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>