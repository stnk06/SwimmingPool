<mah:MetroWindow x:Class="SwimmingPool.Views.QuickRegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="БЫСТРАЯ РЕГИСТРАЦИЯ" 
        SizeToContent="Height" Width="600"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        BorderThickness="1"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}">
    <Grid Margin="20" x:Name="FormGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Новый клиент и абонемент" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Данные клиента" Style="{DynamicResource MahApps.Styles.GroupBox}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="ФИО:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Column="1" Margin="0,5" Text="{Binding Client.FullName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.TextBox}"/>

                    <TextBlock Grid.Row="1" Text="Дата рождения:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" Margin="0,5" SelectedDate="{Binding Client.DateOfBirth, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.DatePicker}"/>

                    <TextBlock Grid.Row="2" Text="Паспорт:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Margin="0,5" Text="{Binding Client.PassportNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.TextBox}"/>

                    <TextBlock Grid.Row="3" Text="Телефон:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Margin="0,5" Text="{Binding Client.PhoneNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.TextBox}"/>

                    <TextBlock Grid.Row="4" Text="Адрес:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Margin="0,5" Text="{Binding Client.Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.TextBox}"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Данные абонемента" Style="{DynamicResource MahApps.Styles.GroupBox}">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Тип:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox Grid.Column="1" Margin="0,5" ItemsSource="{Binding MembershipTypes}" DisplayMemberPath="TypeName" SelectedValuePath="MembershipTypeId" SelectedValue="{Binding Membership.MembershipTypeId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.ComboBox}"/>

                    <TextBlock Grid.Row="1" Text="Дата покупки:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker Grid.Row="1" Grid.Column="1" Margin="0,5" SelectedDate="{Binding Membership.PurchaseDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.DatePicker}"/>

                    <TextBlock Grid.Row="2" Text="Дата окончания:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker Grid.Row="2" Grid.Column="1" Margin="0,5" SelectedDate="{Binding Membership.ExpiryDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Style="{DynamicResource MahApps.Styles.DatePicker}"/>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить и закрыть" IsDefault="True" Click="SaveButton_Click" Margin="5">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Dialogs.Accent}">
                        <Setter Property="IsEnabled" Value="false"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=FormGrid, Path=(Validation.HasError)}" Value="false">
                                <Setter Property="IsEnabled" Value="true"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Отмена" IsCancel="True" Margin="5" Style="{StaticResource MahApps.Styles.Button.Dialogs}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>

