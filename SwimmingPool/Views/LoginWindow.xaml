<mah:MetroWindow x:Class="SwimmingPool.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:viewModels="clr-namespace:SwimmingPool.ViewModels"
        mc:Ignorable="d"
        Title="Авторизация" Height="550" Width="900"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowTitleBar="False"
        BorderThickness="0"
        GlowBrush="{x:Null}">

    <mah:MetroWindow.DataContext>
        <viewModels:LoginViewModel/>
    </mah:MetroWindow.DataContext>

    <!-- Основной контейнер с тенями и скруглением -->
    <Border CornerRadius="20" Background="White" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="#20000000" BlurRadius="30" ShadowDepth="10" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <!-- Левая часть с фото (шире) -->
                <ColumnDefinition Width="*"/>
                <!-- Правая часть с формой -->
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ЧАСТЬ: Фото и Брендинг -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20" ClipToBounds="True">
                <Grid>
                    <!-- Фоновое изображение (Замените Source на ваше фото) -->
                    <!-- Для примера используем градиент, имитирующий воду/бассейн -->
                    <Border>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#007ACC" Offset="0"/>
                                <GradientStop Color="#00B4D8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Canvas>
                            <Ellipse Width="400" Height="400" Canvas.Top="-100" Canvas.Left="-100" Fill="#20FFFFFF"/>
                            <Ellipse Width="200" Height="200" Canvas.Bottom="-50" Canvas.Right="-50" Fill="#10FFFFFF"/>
                        </Canvas>
                    </Border>

                    <!-- Оверлей с текстом -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <iconPacks:PackIconMaterial Kind="Pool" Width="80" Height="80" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <!-- УБРАН LETTERSPACING, ТАК КАК ОН НЕ ПОДДЕРЖИВАЕТСЯ В WPF TEXTBLOCK -->
                        <TextBlock Text="КЛИМОВСКАЯ" FontSize="28" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="СПОРТИВНАЯ ШКОЛА" FontSize="18" FontWeight="Light" Foreground="#E0E0E0" 
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>

                        <Separator Width="50" Margin="0,20" Background="#80FFFFFF"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ПРАВАЯ ЧАСТЬ: Форма входа -->
            <Grid Grid.Column="1">
                <!-- Кнопка закрытия -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Style="{StaticResource MahApps.Styles.Button.Chromeless}"
                        Width="40" Height="40" Margin="0,10,10,0"
                        Click="CloseButton_Click" Panel.ZIndex="10">
                    <iconPacks:PackIconMaterial Kind="Close" Foreground="#999" Width="12" Height="12"/>
                </Button>

                <StackPanel VerticalAlignment="Center" Margin="50">
                    <TextBlock Text="Добро пожаловать" FontSize="26" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>
                    <TextBlock Text="Пожалуйста, войдите в свой аккаунт" FontSize="14" Foreground="#888" Margin="0,0,0,30"/>

                    <!-- Поле Логин -->
                    <TextBlock Text="Логин" Foreground="#666" FontWeight="SemiBold" Margin="5,0,0,5"/>
                    <Grid Margin="0,0,0,20">
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                                 mah:TextBoxHelper.ClearTextButton="True"
                                 mah:ControlsHelper.CornerRadius="8"
                                 Height="45" FontSize="14"
                                 Padding="15,0,35,0"
                                 BorderThickness="1" BorderBrush="#E0E0E0"
                                 Background="#FAFAFA" VerticalContentAlignment="Center"/>
                    </Grid>

                    <!-- Поле Пароль -->
                    <TextBlock Text="Пароль" Foreground="#666" FontWeight="SemiBold" Margin="5,0,0,5"/>
                    <Grid Margin="0,0,0,10">
                        <PasswordBox x:Name="PasswordBox"
                                     mah:ControlsHelper.CornerRadius="8"
                                     Height="45" FontSize="14"
                                     Padding="15,0,35,0"
                                     BorderThickness="1" BorderBrush="#E0E0E0"
                                     Background="#FAFAFA" VerticalContentAlignment="Center"/>
                    </Grid>

                    <Grid Margin="0,0,0,30">
                        <CheckBox Content="Запомнить меня" IsChecked="{Binding RememberMe}" 
                                  VerticalAlignment="Center" Foreground="#888"/>
                    </Grid>

                    <!-- Кнопка входа -->
                    <Button Command="{Binding LoginCommand}" CommandParameter="{Binding ElementName=PasswordBox}"
                            Content="ВОЙТИ" Height="50" FontSize="14" FontWeight="Bold"
                            Style="{StaticResource AccentButtonStyle}"
                            mah:ControlsHelper.CornerRadius="8">
                        <Button.Effect>
                            <DropShadowEffect Color="#4000ABA9" BlurRadius="10" ShadowDepth="4" Direction="270"/>
                        </Button.Effect>
                    </Button>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#FF5252" 
                               HorizontalAlignment="Center" TextAlignment="Center" 
                               TextWrapping="Wrap" Margin="0,20,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</mah:MetroWindow>