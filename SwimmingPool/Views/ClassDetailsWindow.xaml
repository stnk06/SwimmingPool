<mah:MetroWindow x:Class="SwimmingPool.Views.ClassDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="УПРАВЛЕНИЕ ЗАНЯТИЕМ И УЧАСТНИКАМИ" Height="750" Width="1000"
        WindowStartupLocation="CenterOwner"
        BorderThickness="1" GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        SaveWindowPosition="True"
        Language="ru-RU">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0" Header="Параметры занятия" Style="{DynamicResource MahApps.Styles.GroupBox}" Margin="0,0,0,15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ActivityTypes}" DisplayMemberPath="TypeName" SelectedValuePath="ActivityTypeId" SelectedValue="{Binding CurrentClass.ActivityTypeId}" Margin="0,5,15,5"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Тренер:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Row="0" Grid.Column="3" ItemsSource="{Binding Trainers}" DisplayMemberPath="FullName" SelectedValuePath="TrainerId" SelectedValue="{Binding CurrentClass.TrainerId}" Margin="0,5,15,5"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Бассейн:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox Grid.Row="0" Grid.Column="5" ItemsSource="{Binding Pools}" DisplayMemberPath="PoolName" SelectedValuePath="PoolId" SelectedValue="{Binding CurrentClass.PoolId}" Margin="0,5,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Дата:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,5,15,5" 
                         Text="{Binding CurrentClass.StartTime, StringFormat='{}{0:dd.MM.yyyy}', Mode=OneWay}" 
                         IsReadOnly="True" 
                         Background="{DynamicResource MahApps.Brushes.Gray9}" 
                         Foreground="{DynamicResource MahApps.Brushes.Gray3}" 
                         ToolTip="Дата фиксируется при выборе дня в расписании"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Начало:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <mah:TimePicker Grid.Row="1" Grid.Column="3" SelectedDateTime="{Binding CurrentClass.StartTime}" Culture="ru-RU" Margin="0,5,15,5"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Text="Конец:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <mah:TimePicker Grid.Row="1" Grid.Column="5" SelectedDateTime="{Binding CurrentClass.EndTime}" Culture="ru-RU" Margin="0,5,0,5"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Макс. мест:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <mah:NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="1" Value="{Binding CurrentClass.MaxParticipants}" Margin="0,5,15,5"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Доступные клиенты" Style="{DynamicResource MahApps.Styles.GroupBox}">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             mah:TextBoxHelper.Watermark="Поиск клиента..." mah:TextBoxHelper.ClearTextButton="True" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AvailableClientsView}" SelectedItem="{Binding SelectedAvailableClient}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="None" BorderThickness="1" BorderBrush="{DynamicResource MahApps.Brushes.Gray8}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding PhoneNumber}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                <Button Command="{Binding RegisterCommand}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="50" Height="50" Margin="0,0,0,15" ToolTip="Записать на занятие">
                    <iconPacks:PackIconMaterial Kind="ChevronRight" Width="24" Height="24"/>
                </Button>
                <Button Command="{Binding UnregisterCommand}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="50" Height="50" ToolTip="Отменить запись">
                    <iconPacks:PackIconMaterial Kind="ChevronLeft" Width="24" Height="24"/>
                </Button>
            </StackPanel>

            <GroupBox Grid.Column="2" Style="{DynamicResource MahApps.Styles.GroupBox}">
                <GroupBox.Header>
                    <Grid>
                        <TextBlock Text="Записанные участники" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        <Border Background="#2B579A" CornerRadius="12" HorizontalAlignment="Right" Padding="10,2">
                            <TextBlock Text="{Binding RegisteredCountText}" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </GroupBox.Header>
                <Grid Margin="5">
                    <DataGrid ItemsSource="{Binding RegisteredClients}" SelectedItem="{Binding SelectedRegisteredClient}" 
                              AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="None" BorderThickness="1" BorderBrush="{DynamicResource MahApps.Brushes.Gray8}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding PhoneNumber}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="СОХРАНИТЬ И ЗАКРЫТЬ" Command="{Binding SaveClassCommand}" Height="40" Width="200" Style="{DynamicResource AccentButtonStyle}"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>