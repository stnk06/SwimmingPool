<UserControl x:Class="SwimmingPool.Views.ClassesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <UserControl.Resources>
        <!-- Стили для скроллбара и списков внутри ячейки дня -->
        <Style TargetType="ListBox" x:Key="DayClassesListBoxStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,5"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <!-- Убираем стандартное выделение -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F4F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Навигация и заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Дни недели -->
            <RowDefinition Height="*"/>
            <!-- Сетка календаря -->
        </Grid.RowDefinitions>

        <!-- 1. ВЕРХНЯЯ ПАНЕЛЬ (Навигация) -->
        <Grid Grid.Row="0" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="РАСПИСАНИЕ ЗАНЯТИЙ" FontSize="26" FontWeight="Light" Foreground="#333333" Margin="0,0,20,0"/>

                <Button Command="{Binding PrevMonthCommand}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="35" Height="35" Margin="0,0,5,0" ToolTip="Предыдущий месяц">
                    <iconPacks:PackIconMaterial Kind="ChevronLeft"/>
                </Button>

                <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="15,5" MinWidth="180">
                    <TextBlock Text="{Binding CurrentMonthYearText}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#2B579A"/>
                </Border>

                <Button Command="{Binding NextMonthCommand}" Style="{DynamicResource MahApps.Styles.Button.Circle}" Width="35" Height="35" Margin="5,0,0,0" ToolTip="Следующий месяц">
                    <iconPacks:PackIconMaterial Kind="ChevronRight"/>
                </Button>

                <Button Command="{Binding GoToTodayCommand}" Content="СЕГОДНЯ" Margin="15,0,0,0" Style="{DynamicResource MahApps.Styles.Button.Square}" Height="35"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding ExportToPdfCommand}" Margin="0,0,10,0" Height="35" ToolTip="Экспорт расписания в PDF">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                            <Setter Property="Background" Value="#D32F2F"/>
                            <Setter Property="BorderBrush" Value="#D32F2F"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="FilePdfBox" Margin="0 0 5 0" VerticalAlignment="Center"/>
                        <TextBlock Text="Экспорт в PDF" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. ДНИ НЕДЕЛИ (Шапка) -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding DayNames}" Margin="20,0,20,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#2B579A" Padding="10">
                        <TextBlock Text="{Binding}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- 3. СЕТКА КАЛЕНДАРЯ -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Days}" Margin="20,0,20,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0.5" Margin="1">
                        <!-- ИСПРАВЛЕНО ЗДЕСЬ: Добавлен тег Border.Style -->
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTargetMonth}" Value="False">
                                        <Setter Property="Background" Value="#F9F9F9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Grid Margin="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Шапка ячейки (Дата и кнопка "Добавить") -->
                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <!-- Кнопка ДОБАВИТЬ занятие на этот день -->
                                <Button HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Command="{Binding DataContext.AddClassCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                        CommandParameter="{Binding}"
                                        Style="{DynamicResource MahApps.Styles.Button.Flat}" 
                                        Foreground="#2B579A" Padding="2" ToolTip="Добавить занятие">
                                    <iconPacks:PackIconMaterial Kind="PlusCircleOutline" Width="16" Height="16"/>
                                </Button>

                                <TextBlock Text="{Binding Date, StringFormat='dd'}" HorizontalAlignment="Right" VerticalAlignment="Top" FontSize="16" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#333333"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTargetMonth}" Value="False">
                                                    <Setter Property="Foreground" Value="#BDBDBD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>

                            <!-- Список занятий в этот день -->
                            <ListBox Grid.Row="1" ItemsSource="{Binding Classes}" Style="{StaticResource DayClassesListBoxStyle}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#E3F2FD" CornerRadius="4" Padding="5" BorderBrush="#90CAF9" BorderThickness="1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Информация о занятии -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding StartTime, StringFormat='HH:mm'}" FontWeight="Bold" Foreground="#1565C0" FontSize="12"/>
                                                    <TextBlock Text="{Binding ActivityTypeName}" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold" Foreground="#333333" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding TrainerName}" TextWrapping="Wrap" FontSize="11" Foreground="#555555"/>
                                                </StackPanel>

                                                <!-- Кнопки РЕДАКТИРОВАТЬ и УДАЛИТЬ -->
                                                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top" Margin="2,0,0,0">
                                                    <Button Command="{Binding DataContext.EditClassCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource MahApps.Styles.Button.Flat}" 
                                                            Padding="2" Height="20" Width="20" ToolTip="Редактировать/Участники">
                                                        <iconPacks:PackIconMaterial Kind="Pencil" Width="10" Height="10" Foreground="#2E7D32"/>
                                                    </Button>

                                                    <Button Command="{Binding DataContext.DeleteClassCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{DynamicResource MahApps.Styles.Button.Flat}" 
                                                            Padding="2" Height="20" Width="20" Margin="0,2,0,0" ToolTip="Удалить занятие">
                                                        <iconPacks:PackIconMaterial Kind="TrashCanOutline" Width="10" Height="10" Foreground="#C62828"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>