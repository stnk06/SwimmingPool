<mah:MetroWindow x:Class="SwimmingPool.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="ПОЛЬЗОВАТЕЛЬ" SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        BorderThickness="1" GlowBrush="{DynamicResource MahApps.Brushes.Accent}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 0: Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- 1: Логин -->
            <RowDefinition Height="Auto"/>
            <!-- 2: Пароль -->
            <RowDefinition Height="Auto"/>
            <!-- 3: Роль -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Данные учетной записи" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <TextBox Grid.Row="1" x:Name="UsernameBox" 
                 mah:TextBoxHelper.Watermark="Логин" 
                 mah:TextBoxHelper.ClearTextButton="True"
                 Margin="0,0,0,15"/>

        <PasswordBox Grid.Row="2" x:Name="PasswordBox" 
                     mah:TextBoxHelper.Watermark="Пароль" 
                     mah:TextBoxHelper.ClearTextButton="True"
                     Margin="0,0,0,15"/>

        <ComboBox Grid.Row="3" x:Name="RoleBox" 
                  mah:TextBoxHelper.Watermark="Роль пользователя" 
                  Margin="0,0,0,25" SelectedIndex="0">
            <ComboBoxItem Content="User"/>
            <ComboBoxItem Content="Admin"/>
        </ComboBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Click="SaveButton_Click" Style="{StaticResource AccentButtonStyle}" Margin="0,0,10,0" Width="100"/>
            <Button Content="Отмена" IsCancel="True" Style="{StaticResource MahApps.Styles.Button.Dialogs}" Width="80"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>