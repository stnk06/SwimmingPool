<mah:MetroWindow x:Class="SwimmingPool.Views.ClassWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        mc:Ignorable="d"
        Title="ЗАНЯТИЯ" SizeToContent="Height" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        BorderThickness="1" GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        Language="ru-RU">
    <Grid Margin="25" x:Name="FormGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="24" FontWeight="Light" Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- Добавлена новая строка для отдельного вывода даты -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Тип занятия:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <ComboBox Grid.Row="0" Grid.Column="1" Margin="0,5" ItemsSource="{Binding ActivityTypes}" DisplayMemberPath="TypeName" SelectedValuePath="ActivityTypeId" 
                      SelectedValue="{Binding Class.ActivityTypeId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Grid.Row="1" Text="Тренер:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,5" ItemsSource="{Binding Trainers}" DisplayMemberPath="FullName" SelectedValuePath="TrainerId" 
                      SelectedValue="{Binding Class.TrainerId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <TextBlock Grid.Row="2" Text="Бассейн:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,5" ItemsSource="{Binding Pools}" DisplayMemberPath="PoolName" SelectedValuePath="PoolId" 
                      SelectedValue="{Binding Class.PoolId, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>

            <!-- 
                 ЗАБЛОКИРОВАННАЯ ДАТА:
                 Показывается в нужном формате, не может быть изменена руками,
                 чтобы не сбить календарное распределение.
            -->
            <TextBlock Grid.Row="3" Text="Дата занятия:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" Margin="0,5" 
                     Text="{Binding Class.StartTime, StringFormat='{}{0:dd.MM.yyyy}', Mode=OneWay}" 
                     IsReadOnly="True" 
                     Background="{DynamicResource MahApps.Brushes.Gray9}" 
                     Foreground="{DynamicResource MahApps.Brushes.Gray3}" 
                     ToolTip="Дата фиксируется при выборе дня в расписании"/>

            <!-- 
                 ВЫБОР ВРЕМЕНИ (24 часа): 
                 Используется mah:TimePicker с принудительной русской культурой (Culture="ru-RU") 
            -->
            <TextBlock Grid.Row="4" Text="Время начала:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <mah:TimePicker Grid.Row="4" Grid.Column="1" Margin="0,5" 
                            SelectedDateTime="{Binding Class.StartTime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                            Culture="ru-RU" />

            <TextBlock Grid.Row="5" Text="Время окончания:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <mah:TimePicker Grid.Row="5" Grid.Column="1" Margin="0,5" 
                            SelectedDateTime="{Binding Class.EndTime, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                            Culture="ru-RU" />

            <TextBlock Grid.Row="6" Text="Макс. участников:" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <mah:NumericUpDown Grid.Row="6" Grid.Column="1" Margin="0,5" Minimum="0" Value="{Binding Class.MaxParticipants, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" IsDefault="True" Click="SaveButton_Click" Margin="10 0 0 0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=FormGrid, Path=(Validation.HasError)}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Отмена" IsCancel="True" Margin="10 0 0 0"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>