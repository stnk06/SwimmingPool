<mah:MetroWindow x:Class="SwimmingPool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:viewModels="clr-namespace:SwimmingPool.ViewModels"
        xmlns:views="clr-namespace:SwimmingPool.Views"
        mc:Ignorable="d"
        Title="Климовская спортивная школа" Height="768" Width="1366"
        WindowStartupLocation="CenterScreen"
        GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
        BorderThickness="1"
        TitleCharacterCasing="Normal" WindowState="Maximized">

    <mah:MetroWindow.Background>
        <StaticResource ResourceKey="AppBackgroundBrush"/>
    </mah:MetroWindow.Background>

    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ClientsViewModel}">
            <views:ClientsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MembershipsViewModel}">
            <views:MembershipsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ClassesViewModel}">
            <views:ClassesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:TrainersViewModel}">
            <views:TrainersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:MembershipTypesViewModel}">
            <views:MembershipTypesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ActivityTypesViewModel}">
            <views:ActivityTypesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:PoolsViewModel}">
            <views:PoolsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:ReportsViewModel}">
            <views:ReportsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>
        <!-- Добавлен шаблон для расширенной аналитики, чтобы она работала в новом дизайне -->
        <DataTemplate DataType="{x:Type viewModels:AdvancedReportsViewModel}">
            <views:AdvancedReportsView/>
        </DataTemplate>
    </Window.Resources>

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <iconPacks:PackIconMaterial Kind="Pool" Margin="10 0 5 0" Height="24" Width="24" VerticalAlignment="Center"/>
                <TextBlock Text="Система управления бассейном" VerticalAlignment="Center" FontSize="16" FontWeight="Medium"/>
            </StackPanel>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель навигации (эффект стекла) -->
        <Border Grid.Column="0" Background="{StaticResource GlassPanelBackground}" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20" Orientation="Horizontal">
                    <iconPacks:PackIconMaterial Kind="AccountCircle" Width="30" Height="30" Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                    <TextBlock Text="{Binding CurrentUserName}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold" TextWrapping="Wrap" Width="170"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="МЕНЮ" Foreground="Black" FontSize="12" Opacity="0.6" Margin="20 0 0 10" FontWeight="Bold"/>

                <ListBox Grid.Row="2" ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavItem}"
                         Style="{StaticResource MainMenuListBoxStyle}"
                         ItemContainerStyle="{StaticResource MainMenuListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="{Binding Icon}" Width="22" Height="22" Margin="0 0 15 0"/>
                                <TextBlock Text="{Binding Label}" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Кнопка выхода с новым стилем -->
                <Button Grid.Row="3" Command="{Binding LogoutCommand}" Margin="20" Background="#AAFF3434" Foreground="White" >
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="Logout" Margin="0,0,10,0"/>
                        <TextBlock Text="Выйти из системы"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentViewModel}" Margin="15"/>

    </Grid>
</mah:MetroWindow>